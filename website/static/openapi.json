{
  "openapi": "3.1.0",
  "info": {
    "title": "Python Demo API",
    "summary": "A compact FastAPI reference app with rich logging and a Books API.",
    "description": "Companion demo app for the concepts discussed in the docs. The live API focuses on request validation, pagination, partial updates, rich logging, health checks, redirects, and safe demo controls. Authentication and cloud deployment patterns are explained in the documentation.",
    "version": "0.3.0"
  },
